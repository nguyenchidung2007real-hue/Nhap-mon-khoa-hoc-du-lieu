
SELECT 
    COUNT(*) AS SoLuongSanPham,
    AVG(price) AS GiaTrungBinh,
    MIN(price) AS GiaReNhat,
    MAX(price) AS GiaDatNhat
FROM products;



SELECT 
    s.supplier_name AS TenNhaCungCap,
    COUNT(p.productid) AS SoLuongSanPham
FROM suppliers s
INNER JOIN products p ON s.supplier_id = p.productid
GROUP BY s.supplier_id, s.supplier_name
HAVING COUNT(p.productid) > 2;  



SELECT 
    orderid,
    TO_CHAR(orderdate, '%d/%m/%Y') AS orderdate
FROM orders
WHERE EXTRACT(YEAR FROM orderdate) = 2025 
  AND EXTRACT(MONTH FROM orderdate) = 10;



SELECT 
    c.firstname AS TenKhachHang,
    SUM(od.quantity * od.price) AS TongChiTieu
FROM customers c
INNER JOIN orders o ON c.customerid = o.customerid
INNER JOIN orderdetails od ON o.orderid = od.orderid
GROUP BY c.customerid, c.firstname
HAVING SUM(od.quantity * od.price) > 100000
ORDER BY TongChiTieu DESC;
